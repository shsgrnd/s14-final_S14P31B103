{
  "name": "gitcat",
  "displayName": "GitCat",
  "description": "An AI-powered Git assistant for safer commits, conflict prevention, and smarter workflow guidance in VS Code.",
  "publisher": "ssafy",
  "icon": "icon.png",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "gitcat.openPanel",
        "title": "GitCat: Open Panel"
      },
      {
        "command": "gitcat.getGitStatus",
        "title": "GitCat: Refresh Status"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "gitcat-sidebar",
          "title": "GitCat",
          "icon": "$(git-commit)"
        }
      ]
    },
    "views": {
      "gitcat-sidebar": [
        {
          "id": "gitcat-git-view",
          "name": "Git 작업"
        },
        {
          "id": "gitcat-safety-view",
          "name": "안전 계층"
        },
        {
          "id": "gitcat-branch-view",
          "name": "브랜치 정리"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0",
    "@types/node": "18.x",
    "typescript": "^5.0.0"
  }
}